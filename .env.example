DATABASE_URL=postgresql+psycopg2://dbuser:db-password@localhost:5432/mydb
REDIS_URL=redis://redis:6379/0
BLOG_GENERATE_RATE_LIMIT=3
BLOG_GENERATE_RATE_WINDOW_SECONDS=60
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
BLOG_TASKS_TOPIC=blog.tasks
BLOG_SECTIONS_TOPIC=blog.sections
BLOG_EVENTS_TOPIC=blog.events
KAFKA_NUM_TASK_PARTITIONS=6
KAFKA_SECTION_TIMEOUT_SECONDS=180

GEMINI_MODEL_NAME=gemini-2.5-flash
BLOG_GEMINI_MODEL_NAME=

EMAIL_ADDRESS=
EMAIL_PASSWORD=
EMAIL_PROVIDER=smtp
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
SENDGRID_API_KEY=

TAVILY_API_KEY=
GOOGLE_API_KEY=

BLOG_OUTPUT_DIR=data/blog_runs
